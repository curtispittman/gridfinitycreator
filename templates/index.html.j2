{% extends 'templates/base.html.j2' %}

{% block content %}

{# Default component shown on load - the Divider Bin designer. Baseplate is pinned last. #}
{% set default_component = 'classicbin' %}
{% set last_component = 'baseplate' %}
{% set ordered_forms = (forms | selectattr('id', 'equalto', default_component) | list)
  + (forms | rejectattr('id', 'equalto', default_component) | rejectattr('id', 'equalto', last_component) | list)
  + (forms | selectattr('id', 'equalto', last_component) | list) %}

{% macro component_panel(form, hidden) %}
<section class="component-panel{% if hidden %} d-none{% endif %}" data-component="{{ form.id }}">
  <div class="component-grid">

    <div class="gfc-card preview-pane">
      <div class="gfc-card__head">
        <span class="title"><i class="bi bi-badge-3d-fill"></i> 3D Preview</span>
        <span class="hint">Drag to rotate &middot; scroll to zoom</span>
      </div>
      <div class="preview-stage">
        <div id="{{ form.id }}_preview" class="gfc-preview">
          <div id="{{ form.id }}_preview_placeholder" class="preview-placeholder">
            The 3D preview appears here and updates automatically as you change the settings.
          </div>
          <div id="{{ form.id }}_preview_spinner" class="preview-spinner d-none">
            <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading…</span></div>
          </div>
        </div>
        <div id="{{ form.id }}_preview_error" class="preview-error alert alert-warning d-none" role="alert"></div>
      </div>
    </div>

    <div class="gfc-card settings-pane">
      <div class="gfc-card__head">
        <span class="title"><i class="bi bi-sliders"></i> {{ form.get_title() }}</span>
        <button type="submit" form="{{ form.id }}_form" name="{{ form.id }}" id="{{ form.id }}_button"
          class="btn btn-primary btn-sm">
          <i class="bi bi-download" aria-hidden="true"></i>
          <span>Generate</span>
        </button>
      </div>
      <div class="settings-body">
        <details class="component-about">
          <summary><i class="bi bi-info-circle" aria-hidden="true"></i> About the {{ form.get_title() }}</summary>
          <div class="component-about__body">
            {{ form.get_description()|safe }}
          </div>
        </details>
        <form method="post" id="{{ form.id }}_form">
          {{ form.csrf_token() }}
          {{ form.get_settings_html() | inner_render({"form":form}) }}
        </form>
      </div>
    </div>

  </div>
</section>
{% endmacro %}

<header class="app-header">
  <div class="app-header__bar">
    <a class="brand" href="/">
      <span class="brand__icon"><i class="bi bi-box-seam"></i></span>
      <span class="brand__text">Gridfinity Creator</span>
    </a>

    <div class="app-header__actions">
      <button class="icon-btn" type="button" data-bs-toggle="modal" data-bs-target="#about-modal"
        title="About" aria-label="About"><i class="bi bi-info-circle"></i></button>
      <button class="icon-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#settings"
        aria-controls="settings" title="Grid settings" aria-label="Grid settings"><i class="bi bi-gear"></i></button>
    </div>

    <div class="component-picker">
      <label class="component-picker__label" for="component-selector">Component</label>
      <select id="component-selector" class="form-select component-select" aria-label="Choose a component to design">
        {% for form in ordered_forms %}
        <option value="{{ form.id }}"{% if form.id == default_component %} selected{% endif %}>{{ form.get_title() }}</option>
        {% endfor %}
      </select>
    </div>
  </div>
</header>

<main class="workspace">
  {% for form in ordered_forms %}
  {{ component_panel(form, form.id != default_component) }}
  {% endfor %}
</main>

<footer class="app-footer">
  <div>Gridfinity Creator v{{ version }}. &copy; 2024 Jeroen Bouwens.</div>
  <div>
    <a href="https://github.com/jeroen94704/gridfinitycreator">Source</a><span class="sep">&middot;</span>
    <a href="https://discord.gg/fBb2gpzKca">Discord</a><span class="sep">&middot;</span>
    <a href="https://ko-fi.com/jeroen94704">Donate</a>
  </div>
</footer>

{% include 'templates/settings_offcanvas.html.j2' %}

<!-- About modal (was the Home tab) -->
<div id="about-modal" class="modal fade" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">About Gridfinity Creator</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body about-body">
        {% include 'templates/front_page.html.j2' %}
      </div>
    </div>
  </div>
</div>

<!-- Field help modal -->
<div id="help-modal" class="modal fade" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">More information</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body"></div>
    </div>
  </div>
</div>

<script>
  // Show per-field help text in a modal.
  document.body.addEventListener('click', event => {
    const button = event.target.closest('.help-button');
    if (!button) return;

    const modalElement = document.getElementById('help-modal');
    const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
    const content = button.querySelector('[id^="content"]');
    let helpText = content ? content.innerHTML : '';

    if (!helpText || helpText.trim() === '') {
      helpText = 'There is no extra information available for this field.';
    }

    modalElement.querySelector('.modal-body').innerHTML = helpText;
    modal.show();
  }, false);

  window.addEventListener('load', function () {
    const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
    [...tooltipTriggerList].map(el => new bootstrap.Tooltip(el));
  });

  // Grid-size presets (used by the advanced settings offcanvas).
  function presetChanged() {
    const presetName = document.getElementById("grid-presets").value;
    switch (presetName) {
      case "Gridfinity":
        document.getElementById("gridSizeX").value = "42.0";
        document.getElementById("gridSizeY").value = "42.0";
        document.getElementById("gridSizeZ").value = "7.0";
        break;
      case "Raaco":
        document.getElementById("gridSizeX").value = "39.5";
        document.getElementById("gridSizeY").value = "54.5";
        document.getElementById("gridSizeZ").value = "7.0";
        break;
    }
  }
</script>
{% endblock %}
